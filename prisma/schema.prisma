  optometryDetailId String   @unique @map("optometry_detail_id")
  sphere            String? // e.g., "10.00"
  cylinder          String? // e.g., "10.00"
  axis              String? // e.g., "10.00"
  readAdd           String?  @map("read_add") // Reading addition
  prism             String? // e.g., "10.00"
  base              String? // e.g., "OD" (Out and Down)
  conditionDesc     String?  @map("condition_desc")
  diameter          String? // Lens diameter
  createdAt         DateTime @default(now()) @map("created_at")

  optometryDetail OptometryDetail @relation(fields: [optometryDetailId], references: [id], onDelete: Cascade)

  @@map("optometry_lenses")
}

model OptometryFrame {
  id                String   @id @default(cuid())
  optometryDetailId String   @unique @map("optometry_detail_id")
  nvsTagNumber      String?  @map("nvs_tag_number")
  createdAt         DateTime @default(now()) @map("created_at")

  optometryDetail OptometryDetail @relation(fields: [optometryDetailId], references: [id], onDelete: Cascade)

  @@map("optometry_frames")
}

// ==================== STOCK MANAGEMENT MODELS ====================

model Supplier {
  id             String   @id @default(cuid())
  supplierCode   String   @unique @map("supplier_code")
  name           String
  contactPerson  String?  @map("contact_person")
  email          String?
  phone          String?
  address        String?  @db.Text
  vatNumber      String?  @map("vat_number")
  registrationNo String?  @map("registration_no")
  paymentTerms   String?  @map("payment_terms")
  leadTimeDays   Int?     @map("lead_time_days")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  products       ProductSupplier[]
  purchaseOrders PurchaseOrder[]
  stockBatches   StockBatch[]

  @@map("suppliers")
}

model Product {
  id                     String   @id @default(cuid())
  productCode            String   @unique @map("product_code")
  nappiCodeId            String?  @unique @map("nappi_code_id")
  name                   String
  genericName            String?  @map("generic_name")
  category               String // MEDICINE, CONSUMABLE, EQUIPMENT, RADIOLOGY
  type                   String // TABLET, CAPSULE, SYRUP, INJECTION, DRESSING, etc.
  unitOfMeasure          String   @map("unit_of_measure")
  packSize               Int      @default(1) @map("pack_size")
  dispensingUnit         String   @map("dispensing_unit")
  purchasePrice          Float?   @map("purchase_price")
  sellingPriceGeneral    Float?   @map("selling_price_general")
  sellingPriceWorker     Float?   @map("selling_price_worker")
  dispensingFee          Float?   @map("dispensing_fee")
  vatPercentage          Float    @default(15.0) @map("vat_percentage")
  reorderLevel           Int?     @map("reorder_level")
  reorderQuantity        Int?     @map("reorder_quantity")
  maxStockLevel          Int?     @map("max_stock_level")
  leadTimeDays           Int?     @map("lead_time_days")
  drugSchedule           String?  @map("drug_schedule")
  atcCode                String?  @map("atc_code")
  isPrescriptionRequired Boolean  @default(true) @map("is_prescription_required")
  isControlled           Boolean  @default(false) @map("is_controlled")
  isChronic              Boolean  @default(false) @map("is_chronic")
  isCdl                  Boolean  @default(false) @map("is_cdl")
  isActive               Boolean  @default(true) @map("is_active")
  batchTracked           Boolean  @default(true) @map("batch_tracked")
  expiryTracked          Boolean  @default(true) @map("expiry_tracked")
  imageUrl               String?  @map("image_url")
  description            String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  nappiCode            NappiCode?             @relation(fields: [nappiCodeId], references: [id])
  suppliers            ProductSupplier[]
  stockBatches         StockBatch[]
  purchaseOrderItems   PurchaseOrderItem[]
  prescriptionItems    PrescriptionItem[]
  consumptionItems     StockConsumptionItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  stockTransferItems   StockTransferItem[]
  stockAdjustments     StockAdjustment[]
  stockReorderRequests StockReorderRequest[]

  @@index([productCode])
  @@index([category])
  @@map("products")
}

model ProductSupplier {
  id                String  @id @default(cuid())
  productId         String  @map("product_id")
  supplierId        String  @map("supplier_id")
  supplierCode      String? @map("supplier_code")
  isPrimary         Boolean @default(false) @map("is_primary")
  lastPurchasePrice Float?  @map("last_purchase_price")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@map("product_suppliers")
}

model StockBatch {
  id                  String    @id @default(cuid())
  batchNumber         String    @map("batch_number")
  productId           String    @map("product_id")
  supplierId          String?   @map("supplier_id")
  purchaseOrderId     String?   @map("purchase_order_id")
  quantityReceived    Int       @map("quantity_received")
  quantityRemaining   Int       @map("quantity_remaining")
  quantityReserved    Int       @default(0) @map("quantity_reserved")
  costPricePerUnit    Float     @map("cost_price_per_unit")
  sellingPriceGeneral Float     @map("selling_price_general")
  manufacturingDate   DateTime? @map("manufacturing_date")
  expiryDate          DateTime? @map("expiry_date")
  receivedDate        DateTime  @default(now()) @map("received_date")
  status              String    @default("ACTIVE") // ACTIVE, EXPIRED, DEPLETED, QUARANTINED
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  product            Product                @relation(fields: [productId], references: [id])
  supplier           Supplier?              @relation(fields: [supplierId], references: [id])
  purchaseOrder      PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  consumptionItems   StockConsumptionItem[]
  reservations       StockReservation[]
  stockTransferItems StockTransferItem[]
  stockAdjustments   StockAdjustment[]
  nappiCode          NappiCode?             @relation(fields: [nappiCodeId], references: [id])
  nappiCodeId        String?

  @@index([productId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@map("stock_batches")
}

model StockReservation {
  id             String   @id @default(cuid())
  batchId        String   @map("batch_id")
  prescriptionId String?  @map("prescription_id")
  appointmentId  String?  @map("appointment_id")
  quantity       Int
  reservedAt     DateTime @default(now()) @map("reserved_at")
  expiresAt      DateTime @map("expires_at")
  status         String   @default("ACTIVE") // ACTIVE, CONSUMED, CANCELLED, EXPIRED

  batch StockBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([prescriptionId])
  @@map("stock_reservations")
}

model StockConsumptionItem {
  id             String   @id @default(cuid())
  batchId        String   @map("batch_id")
  prescriptionId String?  @map("prescription_id")
  appointmentId  String?  @map("appointment_id")
  doctorId       String?  @map("doctor_id")
  departmentId   String?  @map("department_id")
  quantity       Int
  unitPrice      Float    @map("unit_price")
  totalAmount    Float    @map("total_amount")
  consumedBy     String?  @map("consumed_by")
  consumedAt     DateTime @default(now()) @map("consumed_at")
  notes          String?  @db.Text

  batch     StockBatch @relation(fields: [batchId], references: [id])
  productId String?
  product   Product?   @relation(fields: [productId], references: [id])

  @@index([batchId])
  @@index([prescriptionId])
  @@index([appointmentId])
  @@map("stock_consumption")
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique @map("po_number")
  supplierId   String    @map("supplier_id")
  orderDate    DateTime  @default(now()) @map("order_date")
  expectedDate DateTime? @map("expected_date")
  deliveryDate DateTime? @map("delivery_date")
  status       String    @default("DRAFT") // DRAFT, SUBMITTED, RECEIVED, CANCELLED
  totalAmount  Float?    @map("total_amount")
  vatAmount    Float?    @map("vat_amount")
  grandTotal   Float?    @map("grand_total")
  notes        String?   @db.Text
  createdBy    String?   @map("created_by")
  approvedBy   String?   @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
  grnReceipts  GoodsReceiptNote[]
  stockBatches StockBatch[]

  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String @id @default(cuid())
  poId             String @map("po_id")
  productId        String @map("product_id")
  quantity         Int
  unitPrice        Float  @map("unit_price")
  totalPrice       Float  @map("total_price")
  receivedQuantity Int    @default(0) @map("received_quantity")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

model GoodsReceiptNote {
  id           String   @id @default(cuid())
  grnNumber    String   @unique @map("grn_number")
  poId         String?  @map("po_id")
  receivedDate DateTime @default(now()) @map("received_date")
  receivedBy   String?  @map("received_by")
  status       String   @default("DRAFT") // DRAFT, COMPLETED
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  purchaseOrder PurchaseOrder?     @relation(fields: [poId], references: [id])
  items         GoodsReceiptItem[]

  @@index([grnNumber])
  @@map("goods_receipt_notes")
}

model GoodsReceiptItem {
  id                String    @id @default(cuid())
  grnId             String    @map("grn_id")
  productId         String    @map("product_id")
  poItemId          String?   @map("po_item_id")
  batchNumber       String    @map("batch_number")
  quantityReceived  Int       @map("quantity_received")
  quantityAccepted  Int       @map("quantity_accepted")
  quantityRejected  Int       @default(0) @map("quantity_rejected")
  rejectReason      String?   @map("reject_reason")
  manufacturingDate DateTime? @map("manufacturing_date")
  expiryDate        DateTime? @map("expiry_date")
  costPricePerUnit  Float     @map("cost_price_per_unit")

  goodsReceipt GoodsReceiptNote @relation(fields: [grnId], references: [id])
  product      Product          @relation(fields: [productId], references: [id])

  @@map("goods_receipt_items")
}

model StockTransfer {
  id             String   @id @default(cuid())
  transferNumber String   @unique @map("transfer_number")
  fromDepartment String?  @map("from_department")
  toDepartment   String?  @map("to_department")
  fromDoctorId   String?  @map("from_doctor_id")
  toDoctorId     String?  @map("to_doctor_id")
  transferDate   DateTime @default(now()) @map("transfer_date")
  status         String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  requestedBy    String?  @map("requested_by")
  approvedBy     String?  @map("approved_by")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  items StockTransferItem[]

  @@index([transferNumber])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String @id @default(cuid())
  transferId String @map("transfer_id")
  batchId    String @map("batch_id")
  productId  String @map("product_id")
  quantity   Int

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  batch    StockBatch    @relation(fields: [batchId], references: [id])
  product  Product       @relation(fields: [productId], references: [id])

  @@map("stock_transfer_items")
}

model StockAdjustment {
  id               String   @id @default(cuid())
  adjustmentNumber String   @unique @map("adjustment_number")
  batchId          String   @map("batch_id")
  productId        String   @map("product_id")
  adjustmentType   String   @map("adjustment_type") // WASTAGE, EXPIRED, DAMAGED, COUNT_CORRECTION, RETURN
  quantity         Int // Positive for increase, negative for decrease
  reason           String   @db.Text
  adjustedBy       String?  @map("adjusted_by")
  approvedBy       String?  @map("approved_by")
  adjustedAt       DateTime @default(now()) @map("adjusted_at")
  createdAt        DateTime @default(now()) @map("created_at")

  batch   StockBatch @relation(fields: [batchId], references: [id])
  product Product    @relation(fields: [productId], references: [id])

  @@index([batchId])
  @@map("stock_adjustments")
}

model StockReorderRequest {
  id              String    @id @default(cuid())
  productId       String    @map("product_id")
  currentStock    Int       @map("current_stock")
  reorderLevel    Int       @map("reorder_level")
  reorderQuantity Int       @map("reorder_quantity")
  status          String    @default("PENDING") // PENDING, APPROVED, ORDERED, CANCELLED
  requestedAt     DateTime  @default(now()) @map("requested_at")
  processedAt     DateTime? @map("processed_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([status])
  @@map("stock_reorder_requests")
}

// ==================== AI & OTHER MODELS ====================

model AiConsultationSummary {
  id              String   @id @default(cuid())
  appointmentId   String   @unique @map("appointment_id")
  summary         String   @db.LongText
  keyFindings     Json?    @map("key_findings")
  recommendations Json?    @map("recommendations")
  prescriptions   Json?    @map("prescriptions")
  diagnoses       Json?    @map("diagnoses")
  confidence      Float?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("ai_consultation_summaries")
}

model Invite {
  id              String   @id @default(cuid())
  token           String   @unique
  email           String
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  phone           String?
  patientId       String?  @map("patient_id")
  doctorId        String   @map("doctor_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentSlot String   @map("appointment_slot")
  status          String   @default("PENDING")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([status])
  @@map("invites")
}

// ==================== AUDIT LOG MODEL ====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  userType   String?  @map("user_type") // DOCTOR, STAFF, PATIENT, ADMIN
  action     String // CREATE, UPDATE, DELETE, VIEW, SUBMIT, REVERSE
  entityType String   @map("entity_type") // Patient, Claim, Bill, Appointment, etc.
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== ERA PROVIDER MODEL ====================

model EraProvider {
  id             String   @id @default(cuid())
  eraId          String   @map("era_id")
  doctorId       String   @map("doctor_id")
  providerNumber String   @map("provider_number") // BHF number
  providerName   String   @map("provider_name")
  providerGroup  String?  @map("provider_group")
  createdAt      DateTime @default(now()) @map("created_at")

  era    Era    @relation(fields: [eraId], references: [id], onDelete: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([eraId, doctorId])
  @@map("era_providers")
}
