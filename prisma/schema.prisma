  admittingId   String?  @map("admitting_id") // Doctor ID for admitting
  createdAt     DateTime @default(now()) @map("created_at")

  claim       Claim       @relation(fields: [claimId], references: [id], onDelete: Cascade)
  prescribing Doctor?     @relation("PrescribingDoctor", fields: [prescribingId], references: [id])
  referring   Doctor?     @relation("ReferringDoctor", fields: [referringId], references: [id])
  admitting   Doctor?     @relation("AdmittingDoctor", fields: [admittingId], references: [id])
